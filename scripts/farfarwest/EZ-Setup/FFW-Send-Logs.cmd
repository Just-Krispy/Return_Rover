@echo off
setlocal EnableExtensions
title Far Far West - Send Logs to Ryan

net session >nul 2>&1
if not "%errorlevel%"=="0" (
  echo Asking Windows for Administrator permission...
  powershell -NoProfile -ExecutionPolicy Bypass -Command "Start-Process -FilePath '%~f0' -Verb RunAs"
  exit /b
)

echo Far Far West - Send Logs to Ryan
echo.
echo This will collect UE4SS logs, settings, and config from your install
echo and save them as a zip on your Desktop.
echo.
echo BEFORE running this:
echo   1. Run the fix script and let the game launch
echo   2. Sit at the main menu for 30 seconds, then close the game
echo   3. Then run this script
echo.
echo The resulting zip file is what you text or email back to Ryan.
echo.
pause

set "B64="
set "B64=%B64%"
set "B64=%B64%"

set "PSFILE=%TEMP%\ffw-tool-%RANDOM%-%RANDOM%.ps1"
powershell -NoProfile -ExecutionPolicy Bypass -Command "[IO.File]::WriteAllBytes($env:PSFILE, [Convert]::FromBase64String($env:B64))"
if not exist "%PSFILE%" (
  echo Failed to write embedded script. Aborting.
  pause
  exit /b 1
)

powershell -NoProfile -ExecutionPolicy Bypass -File "%PSFILE%"
set "EXITCODE=%ERRORLEVEL%"

del "%PSFILE%" >nul 2>&1

exit /b %EXITCODE%
